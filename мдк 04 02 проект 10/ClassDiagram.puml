@startuml
title ClassDiagram

class User {
  - userId: int
  - username: string
  - email: string
  + login()
  + logout()
}

class FinancialRecord {
  - recordId: int
  - userId: int
  - date: Date
  - amount: decimal
  - category: string
  - description: string
  + createRecord()
  + updateRecord()
  + deleteRecord()
}

class Category {
  - categoryId: int
  - name: string
  - type: string
}

class TableView {
  - viewId: int
  - userId: int
  + sortData()
  + filterData()
  + exportData()
}

class ExportManager {
  - managerId: int
  + exportToExcel()
  + exportToPDF()
  + exportToCSV()
}

User "1" -- "many" FinancialRecord
User "1" -- "many" TableView
Category "1" -- "many" FinancialRecord
TableView "1" -- "1" ExportManager
@enduml