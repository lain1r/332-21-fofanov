@startuml
title PUML

entity users {
  * user_id: INT <<PK>>
  --
  username: VARCHAR(50)
  email: VARCHAR(100)
  password: VARCHAR(255)
  created_at: DATETIME
}

entity financial_records {
  * record_id: INT <<PK>>
  * user_id: INT <<FK>>
  --
  record_date: DATE
  amount: DECIMAL(15,2)
  category: VARCHAR(50)
  description: TEXT
  type: ENUM('income', 'expense')
}

entity categories {
  * category_id: INT <<PK>>
  * user_id: INT <<FK>>
  --
  category_name: VARCHAR(50)
  category_type: ENUM('income', 'expense')
}

entity table_views {
  * view_id: INT <<PK>>
  * user_id: INT <<FK>>
  --
  view_name: VARCHAR(50)
  filters: TEXT
  sort_order: VARCHAR(100)
}

users ||--o{ financial_records
users ||--o{ categories
users ||--o{ table_views
categories ||--o{ financial_records
@enduml