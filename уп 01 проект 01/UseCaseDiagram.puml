@startuml
title UseCaseDiagram

actor User
actor Admin

rectangle "Управление личными финансами" {
  usecase "Регистрация" as UC1
  usecase "Авторизация" as UC2
  usecase "Управление счетами" as UC3
  usecase "Добавление транзакций" as UC4
  usecase "Просмотр отчетов" as UC5
  usecase "Установка бюджетов" as UC6
  usecase "Анализ расходов" as UC7
  usecase "Экспорт данных" as UC8
  usecase "Управление пользователями" as UC9
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8

Admin --> UC9
Admin --> UC5

UC3 .> UC4 : include
UC5 .> UC7 : include
UC6 .> UC7 : extend
@enduml